{
  "name": "spoc",
  "version": "1.0.0",
  "description": "MCP server for agentic DAG project management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spoc": "dist/index.js",
    "spoc-cli": "scripts/spoc-cli.mjs"
  },
  "files": [
    "dist/",
    "templates/",
    "skills/",
    "opencode/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "build:opencode-bundle": "node scripts/build-opencode-superpowers-bundle.mjs",
    "prepack": "npm run build:opencode-bundle",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "init": "npm run build && node dist/index.js init",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --fix src/ test/",
    "format": "biome format --write src/ test/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "picocolors": "^1.1.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "private": true
}
